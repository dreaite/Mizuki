---
import fs from "node:fs";
import path from "node:path";
import { Icon } from "astro-icon/components";

import { navBarConfig, siteConfig } from "../../../config";
import { LinkPresets } from "../../../constants/link-presets";
import {
	SUPPORTED_LOCALES,
	getCurrentLocalePath,
	getDefaultLocaleInfo,
	getLocaleSwitchPath,
	isLocalizedHomePath,
} from "../../../i18n/locale";
import { LinkPreset, type NavBarLink } from "../../../types/config";
import type { LocaleSwitchPathMap } from "../../../utils/locale-switch-utils";
import { localizedUrl, url } from "../../../utils/url-utils";
import LayoutSwitch from "../../control/LayoutSwitch.svelte";
import ThemeSwitch from "../../control/ThemeSwitch.svelte";
import DisplaySettings from "../../features/settings/DisplaySettings.svelte";
import WallpaperSwitch from "../../features/settings/WallpaperSwitch.svelte";
import MobileTOC from "../../features/toc/MobileTOC.svelte";
import DropdownMenu from "./DropdownMenu.astro";
import NavMenuPanel from "./NavMenuPanel.astro";
import Search from "./Search.svelte";

interface Props {
	class?: string;
	localeSwitchPaths?: LocaleSwitchPathMap;
}

const { class: className, localeSwitchPaths = {} } = Astro.props as Props;

// 获取导航栏透明模式配置
const navbarTransparentMode =
	siteConfig.banner?.navbar?.transparentMode || "semi";

// 获取整体布局方案切换按钮显示设置
const modeSwitchDisplay =
	siteConfig.wallpaperMode?.showModeSwitchOnMobile || "desktop";

// 检查是否为首页
const isHomePage = isLocalizedHomePath(Astro.url.pathname);

// featurePage URL -> config key mapping
const featurePageUrlMap: Record<string, string> = {
	"/anime/": "anime",
	"/eroge/": "eroge",
	"/diary/": "diary",
	"/friends/": "friends",
	"/projects/": "projects",
	"/skills/": "skills",
	"/timeline/": "timeline",
	"/albums/": "albums",
	"/devices/": "devices",
};

function isFeaturePageDisabled(url: string): boolean {
	const key = featurePageUrlMap[url];
	if (
		key &&
		!siteConfig.featurePages[key as keyof typeof siteConfig.featurePages]
	) {
		return true;
	}
	return false;
}

function filterLinksByFeaturePages(
	items: (NavBarLink | LinkPreset)[],
): NavBarLink[] {
	return items
		.map((item: NavBarLink | LinkPreset): NavBarLink | null => {
			if (typeof item === "number") {
				const resolved = LinkPresets[item];
				if (isFeaturePageDisabled(resolved.url)) {
					return null;
				}
				return resolved;
			}
			if (isFeaturePageDisabled(item.url)) {
				return null;
			}
			if (item.children) {
				const filteredChildren = filterLinksByFeaturePages(item.children);
				if (filteredChildren.length === 0) {
					return null;
				}
				return { ...item, children: filteredChildren };
			}
			return item;
		})
		.filter((item): item is NavBarLink => item !== null);
}

const links: NavBarLink[] = filterLinksByFeaturePages(navBarConfig.links);

const isExternalAsset = (asset?: string) =>
	asset?.match(/^(http|https|\/\/|data:)/);

const publicAssetExists = (asset?: string) => {
	if (!asset || isExternalAsset(asset)) {
		return false;
	}
	const publicPath = asset.split(/[?#]/)[0]?.replace(/^\/+/, "");
	if (!publicPath || publicPath.includes("..")) {
		return false;
	}
	return fs.existsSync(path.join(process.cwd(), "public", publicPath));
};

const rawLogo = siteConfig.navbarTitle?.logo;
const logoSrc = isExternalAsset(rawLogo)
	? rawLogo
	: rawLogo
		? url(rawLogo)
		: "";

const rawIcon = siteConfig.navbarTitle?.icon;
const iconSrc = isExternalAsset(rawIcon)
	? rawIcon
	: rawIcon
		? url(rawIcon)
		: "";

const logoWebpRaw = rawLogo?.replace(/\.png$/i, ".webp");
const iconWebpRaw = rawIcon?.replace(/\.png$/i, ".webp");
const hasLogoWebpFallback =
	rawLogo?.endsWith(".png") && publicAssetExists(logoWebpRaw);
const hasIconWebpFallback =
	rawIcon?.endsWith(".png") && publicAssetExists(iconWebpRaw);
const logoWebpSrc = hasLogoWebpFallback && logoWebpRaw ? url(logoWebpRaw) : "";
const iconWebpSrc = hasIconWebpFallback && iconWebpRaw ? url(iconWebpRaw) : "";
const currentLocalePath = getCurrentLocalePath();
const currentLocale =
	SUPPORTED_LOCALES.find((locale) => locale.path === currentLocalePath) ||
	SUPPORTED_LOCALES[0];
const defaultLocalePath = getDefaultLocaleInfo().path;
const languageOptions = SUPPORTED_LOCALES.map((locale) => ({
	...locale,
	href:
		localeSwitchPaths[locale.path] ??
		getLocaleSwitchPath(Astro.url.pathname + Astro.url.search, locale.path),
	active: locale.path === currentLocalePath,
}));
---
<div id="navbar" class="z-50 onload-animation group" data-transparent-mode={navbarTransparentMode} data-is-home={isHomePage} data-default-locale={defaultLocalePath}>
    <div class="absolute h-8 left-0 right-0 -top-8 bg-[var(--card-bg)] transition"></div> <!-- used for onload animation -->
    <div class:list={[className, "!overflow-visible max-w-[var(--page-width)] h-[4.5rem] mx-auto flex items-center justify-between px-4"]}>
        <a href={localizedUrl('/')} class="btn-plain scale-animation rounded-lg h-[2.5rem] md:h-[3.25rem] md:[.enable-banner_&]:h-[2.5rem] md:[.enable-banner_&]:group-[.scrolled]:h-[3.25rem] px-5 font-bold active:scale-95 shrink-0 transition-all duration-300">
            <div class="flex flex-row items-center text-md">
				{/* 使用navbarTitle配置或默认配置 */}
                {siteConfig.navbarTitle ? (
                    siteConfig.navbarTitle.mode === "logo" ? (
                        hasLogoWebpFallback ? (
                            <picture>
                                <source srcset={logoWebpSrc} type="image/webp" />
                                <img src={logoSrc} alt={siteConfig.navbarTitle.text} class="h-[2.5rem] md:h-[3.25rem] md:[.enable-banner_&]:h-[2.5rem] md:[.enable-banner_&]:group-[.scrolled]:h-[3.25rem] max-w-full object-contain transition-all duration-300" loading="lazy" />
                            </picture>
                        ) : (
                            <img src={logoSrc} alt={siteConfig.navbarTitle.text} class="h-[2.5rem] md:h-[3.25rem] md:[.enable-banner_&]:h-[2.5rem] md:[.enable-banner_&]:group-[.scrolled]:h-[3.25rem] max-w-full object-contain transition-all duration-300" loading="lazy" />
                        )
                    ) : (
                        <>
                            {hasIconWebpFallback ? (
                                <picture>
                                    <source srcset={iconWebpSrc} type="image/webp" />
                                    <img src={iconSrc} alt="" class="h-[1.75rem] w-[1.75rem] mr-2 object-contain" loading="lazy" />
                                </picture>
                            ) : (
                                <img src={iconSrc} alt="" class="h-[1.75rem] w-[1.75rem] mr-2 object-contain" loading="lazy" />
                            )}
                            <span class="dark:text-white text-black">{siteConfig.navbarTitle.text}</span>
                        </>
                    )
                ) : (
                    <>
                        <Icon name="material-symbols:home-pin-outline" class="text-[1.75rem] mr-2" />
                        <span class="dark:text-white text-black">{siteConfig.title}</span>
                    </>
                )}
            </div>
        </a>
        <div id="navbar-links-container" class="hidden md:flex items-center space-x-1 transition-opacity duration-300">
            {links.map((l) => {
                return <DropdownMenu link={l} />;
            })}
        </div>
        <div class="flex items-center gap-1">
            <div id="search-container">
                <Search client:only="svelte"></Search>
            </div>
            {/* 只在 sidebar 模式下显示移动端 TOC 按钮 */}
			{siteConfig.toc.enable && siteConfig.toc.mobileTop && <MobileTOC client:only="svelte"></MobileTOC>}
            {!siteConfig.themeColor.fixed && (
                    <button aria-label="Display Settings" class="btn-plain scale-animation rounded-lg h-11 w-11 active:scale-90" id="display-settings-switch">
                        <Icon name="material-symbols:palette-outline" class="text-[1.25rem]"></Icon>
                    </button>
            )}
            <LayoutSwitch client:only="svelte" currentLayout={siteConfig.postListLayout.defaultMode}></LayoutSwitch>
            <div class="language-switcher hidden sm:block relative group" data-language-switcher>
                <button
                    aria-label="Language"
                    aria-haspopup="true"
                    aria-expanded="false"
                    class="btn-plain scale-animation rounded-lg h-11 px-3 active:scale-90 flex items-center gap-1.5 font-bold"
                    data-language-trigger
                >
                    <Icon name="material-symbols:translate" class="text-[1.2rem]"></Icon>
                    <span class="text-xs" data-current-language-label>{currentLocale.shortLabel}</span>
                    <Icon name="material-symbols:keyboard-arrow-down-rounded" class="text-[1.1rem] transition-transform duration-200 language-arrow"></Icon>
                </button>
                <div class="language-menu">
                    <div class="language-menu-content">
                        {languageOptions.map((locale) => (
                            <a
                                href={locale.href}
                                class:list={[
                                    "language-menu-item",
                                    { "language-menu-item-active": locale.active },
                                ]}
                                aria-current={locale.active ? "page" : null}
                                data-no-swup
                                data-language-option
                                data-locale-path={locale.path}
                                data-locale-short-label={locale.shortLabel}
                            >
                                <span>{locale.label}</span>
                                <Icon
                                    name="material-symbols:check-rounded"
                                    class:list={[
                                        "text-[1rem] text-[var(--primary)]",
                                        { hidden: !locale.active },
                                    ]}
                                    data-language-check
                                ></Icon>
                            </a>
                        ))}
                    </div>
                </div>
            </div>
            <!-- 整体布局方案切换按钮：根据配置决定在哪些设备上显示 -->
            <div class:list={[
                modeSwitchDisplay === "off" ? "hidden" :
                modeSwitchDisplay === "mobile" ? "block md:hidden" :
                modeSwitchDisplay === "desktop" ? "hidden md:block" :
                modeSwitchDisplay === "both" ? "block" : "hidden md:block"
            ]}>
                <WallpaperSwitch client:only="svelte"></WallpaperSwitch>
            </div>
            <ThemeSwitch client:only="svelte"></ThemeSwitch>
            <button aria-label="Menu" name="Nav Menu" class="btn-plain scale-animation rounded-lg w-11 h-11 active:scale-90 md:!hidden" id="nav-menu-switch">
                <Icon name="material-symbols:unfold-more" class="text-[1.25rem]"></Icon>
            </button>
        </div>
        <NavMenuPanel links={links} localeSwitchPaths={localeSwitchPaths}></NavMenuPanel>
        <DisplaySettings client:only="svelte"></DisplaySettings>
    </div>
</div>

<script>
	const searchContainer = document.getElementById("search-container");
	const navbarLinksContainer = document.getElementById("navbar-links-container");
	const navbar = document.getElementById("navbar");
	const languageSwitcher = document.querySelector("[data-language-switcher]");
	const languageTrigger = document.querySelector("[data-language-trigger]");
	const languageOptions = Array.from(
		document.querySelectorAll("[data-language-option]"),
	);
	const defaultLocalePath = navbar?.dataset.defaultLocale || "cn";
	const localePaths = Array.from(
		new Set(
			languageOptions
				.map((option) =>
					option instanceof HTMLElement
						? option.dataset.localePath
						: "",
				)
				.filter(Boolean),
		),
	);

	function stripLocaleFromPathname(pathname: string) {
		const normalized = pathname.startsWith("/") ? pathname : `/${pathname}`;
		const segments = normalized.split("/").filter(Boolean);
		const firstSegment = segments[0];

		if (localePaths.includes(firstSegment)) {
			let pathWithoutLocale = `/${segments.slice(1).join("/")}`;
			if (pathWithoutLocale === "/" || pathWithoutLocale === "") {
				pathWithoutLocale = "/";
			} else if (
				normalized.endsWith("/") &&
				!pathWithoutLocale.endsWith("/")
			) {
				pathWithoutLocale += "/";
			}

			return {
				localePath: firstSegment,
				pathWithoutLocale,
			};
		}

		return {
			localePath: defaultLocalePath,
			pathWithoutLocale: normalized || "/",
		};
	}

	function getLanguageSwitchHref(targetLocalePath: string) {
		const localeSwitchPathCarrier =
			document.getElementById("swup-container");
		const rawLocaleSwitchPaths =
			localeSwitchPathCarrier?.dataset.localeSwitchPaths;
		if (rawLocaleSwitchPaths) {
			try {
				const localeSwitchPaths = JSON.parse(rawLocaleSwitchPaths);
				const href = localeSwitchPaths?.[targetLocalePath];
				if (typeof href === "string" && href.length > 0) {
					return window.location.hash && !href.includes("#")
						? `${href}${window.location.hash}`
						: href;
				}
			} catch {
				// Fall back to generic path switching below.
			}
		}

		const route = stripLocaleFromPathname(window.location.pathname);
		const targetPath = `/${targetLocalePath}${
			route.pathWithoutLocale === "/" ? "/" : route.pathWithoutLocale
		}`;
		return `${targetPath}${window.location.search}${window.location.hash}`;
	}

	function syncLanguageSwitcher() {
		if (localePaths.length === 0) {
			return;
		}

		const currentLocalePath = stripLocaleFromPathname(
			window.location.pathname,
		).localePath;
		let currentShortLabel = currentLocalePath.toUpperCase();

		for (const option of languageOptions) {
			if (!(option instanceof HTMLAnchorElement)) {
				continue;
			}

			const localePath = option.dataset.localePath;
			if (!localePath) {
				continue;
			}

			const isActive = localePath === currentLocalePath;
			option.href = getLanguageSwitchHref(localePath);
			option.classList.toggle("language-menu-item-active", isActive);
			option.classList.toggle("text-[var(--primary)]", isActive);

			if (isActive) {
				option.setAttribute("aria-current", "page");
				currentShortLabel =
					option.dataset.localeShortLabel || currentShortLabel;
			} else {
				option.removeAttribute("aria-current");
			}

			option
				.querySelector("[data-language-check]")
				?.classList.toggle("hidden", !isActive);
		}

		document
			.querySelectorAll("[data-current-language-label]")
			.forEach((label) => {
				label.textContent = currentShortLabel;
			});
	}

	function setupLanguageSwitcherSync() {
		syncLanguageSwitcher();
		if (window.swup?.hooks && !window.__mizukiLanguageSwitcherHooked) {
			window.__mizukiLanguageSwitcherHooked = true;
			window.swup.hooks.on("page:view", syncLanguageSwitcher);
			window.swup.hooks.on("content:replace", syncLanguageSwitcher);
		}
	}

	if (languageSwitcher && languageTrigger) {
		languageTrigger.addEventListener("click", () => {
			const isExpanded =
				languageTrigger.getAttribute("aria-expanded") === "true";
			languageTrigger.setAttribute("aria-expanded", String(!isExpanded));
		});
		document.addEventListener("click", (event) => {
			if (!(event.target instanceof Node)) {
				return;
			}
			if (!languageSwitcher.contains(event.target)) {
				languageTrigger.setAttribute("aria-expanded", "false");
			}
		});
	}

	setupLanguageSwitcherSync();
	document.addEventListener("swup:enable", setupLanguageSwitcherSync);
	window.addEventListener("popstate", syncLanguageSwitcher);

	if (searchContainer && navbarLinksContainer) {
		// 鼠标移入/触摸开始时隐藏导航链接
		const hideLinks = () => {
			if (window.matchMedia("(min-width: 1280px)").matches && window.matchMedia("(hover: hover)").matches) {
				navbarLinksContainer.style.opacity = "0";
			}
		};

		// 鼠标移出/触摸结束时显示导航链接
		const showLinks = () => {
			const navbar = document.getElementById("navbar");
			if (navbar && !navbar.classList.contains("is-searching")) {
				navbarLinksContainer.style.opacity = "1";
			}
		};

		searchContainer.addEventListener("mouseenter", hideLinks);
		searchContainer.addEventListener("mouseleave", showLinks);

		// 移动端/触摸屏支持
		searchContainer.addEventListener("touchstart", hideLinks, { passive: true });
		searchContainer.addEventListener("touchend", showLinks);

		// 监听 navbar 的 class 变化，当搜索框折叠时确保链接显示
		if (navbar) {
			const observer = new MutationObserver((mutations) => {
				mutations.forEach((mutation) => {
					if (mutation.type === "attributes" && mutation.attributeName === "class") {
						if (!navbar.classList.contains("is-searching")) {
							// 搜索框已折叠，如果此时鼠标不在搜索容器内，强制显示链接
							if (!searchContainer.matches(':hover')) {
								showLinks();
							}
						}
					}
				});
			});
			observer.observe(navbar, { attributes: true });
		}
	}

async function loadButtonScript() {
    try {
        const { panelManager } = await import('../../../utils/panel-manager.js');
        
        const settingBtn = document.getElementById("display-settings-switch");
        if (settingBtn) {
            settingBtn.onclick = async function () {
                await panelManager.togglePanel('display-setting');
            };
        }

        const menuBtn = document.getElementById("nav-menu-switch");
        if (menuBtn) {
            menuBtn.onclick = async function () {
                await panelManager.togglePanel('nav-menu-panel');
            };
        }
    } catch (error) {
        console.error('Failed to load panel manager:', error);
        // 备用逻辑
        const settingBtn = document.getElementById("display-settings-switch");
        if (settingBtn) {
            settingBtn.onclick = function () {
                const settingPanel = document.getElementById("display-setting");
                if (settingPanel) {
                    settingPanel.classList.toggle("float-panel-closed");
                }
            };
        }

        const menuBtn = document.getElementById("nav-menu-switch");
        if (menuBtn) {
            menuBtn.onclick = function () {
                const menuPanel = document.getElementById("nav-menu-panel");
                if (menuPanel) {
                    menuPanel.classList.toggle("float-panel-closed");
                }
            };
        }
    }
}

loadButtonScript();

// 为semifull模式添加滚动检测逻辑
function initSemifullScrollDetection() {
    const navbar = document.getElementById('navbar');
    if (!navbar) {return;}
    
    // 移除之前的滚动事件监听器（如果存在）
    // @ts-ignore
    if (window.semifullScrollHandler) {
        // @ts-ignore
        window.removeEventListener('scroll', window.semifullScrollHandler);
    }
    
    // 获取当前是否为首页
    // @ts-ignore
    const isHomePage = navbar.dataset.isHome === 'true';

    // 如果不是首页，在平板/桌面端强制显示为scrolled状态
    if (!isHomePage) {
        navbar.classList.add('scrolled');
        return;
    }
    
    let ticking = false;
    
    function updateNavbarState() {
        const scrollTop = window.scrollY || document.documentElement.scrollTop;
        const threshold = 50; // 滚动阈值，可以根据需要调整
        
        if (navbar && scrollTop > threshold) {
            navbar.classList.add('scrolled');
        } else if (navbar) {
            navbar.classList.remove('scrolled');
        }
        
        ticking = false;
    }
    
    function requestTick() {
        if (!ticking) {
            requestAnimationFrame(updateNavbarState);
            ticking = true;
        }
    }
    
    // 保存新的事件处理器引用
    // @ts-ignore
    window.semifullScrollHandler = requestTick;
    
    // 监听滚动事件
    window.addEventListener('scroll', requestTick, { passive: true });
    
    // 初始化状态
    updateNavbarState();
}

// 将函数暴露到全局对象，供页面切换时调用
// @ts-ignore
window.initSemifullScrollDetection = initSemifullScrollDetection;

// 页面加载完成后初始化滚动检测
if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initSemifullScrollDetection);
} else {
    initSemifullScrollDetection();
}
</script>

<style>
	@reference "tailwindcss";

	.language-switcher {
		@apply relative;
	}

	.language-menu {
		@apply absolute top-full right-0 pt-2 opacity-0 invisible pointer-events-none translate-y-[-8px] transition-all duration-200 ease-out z-50;
	}

	.language-switcher:hover .language-menu,
	.language-switcher:focus-within .language-menu,
	.language-switcher
		[data-language-trigger][aria-expanded="true"]
		+ .language-menu {
		@apply opacity-100 visible pointer-events-auto translate-y-0;
	}

	.language-switcher:hover .language-arrow,
	.language-switcher:focus-within .language-arrow,
	.language-switcher
		[data-language-trigger][aria-expanded="true"]
		.language-arrow {
		@apply rotate-180;
	}

	.language-menu-content {
		@apply bg-[var(--float-panel-bg)] rounded-[var(--radius-large)] shadow-xl dark:shadow-none border border-black/5 dark:border-white/10 p-2 min-w-[9.5rem];
	}

	.language-menu-item {
		@apply flex items-center justify-between gap-3 px-4 py-2.5 text-black/75 dark:text-white/75 hover:text-[var(--primary)] hover:bg-[var(--btn-plain-bg-hover)] transition-colors duration-150 font-medium rounded-lg whitespace-nowrap;
	}

	.language-menu-item-active {
		@apply text-[var(--primary)] bg-[var(--btn-plain-bg-hover)];
	}
</style>

{import.meta.env.PROD && <script is:inline define:vars={{scriptUrl: url('/pagefind/pagefind.js')}}>
window.loadPagefind = async function() {
    if (window.pagefind) {return;}
    try {
        const response = await fetch(scriptUrl, { method: 'HEAD' });
        if (!response.ok) {
            throw new Error(`Pagefind script not found: ${response.status}`);
        }

        const pagefind = await import(scriptUrl);

        await pagefind.options({
            excerptLength: 20
        });

        window.pagefind = pagefind;

        document.dispatchEvent(new CustomEvent('pagefindready'));
        console.log('Pagefind loaded and initialized successfully, event dispatched.');
    } catch (error) {
        console.error('Failed to load Pagefind:', error);
        window.pagefind = {
            search: () => Promise.resolve({ results: [] }),
            options: () => Promise.resolve(),
        };
        document.dispatchEvent(new CustomEvent('pagefindloaderror'));
        console.log('Pagefind load error, event dispatched.');
    }
};
</script>}
